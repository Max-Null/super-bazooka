{
  "$schema": "https://raw.githubusercontent.com/nicepage/nicepage/refs/heads/main/schemas/tauri/config.schema.json",
  "productName": "Super Bazooka",
  "version": "0.8.0",
  "identifier": "com.maxnull.super-bazooka",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Super Bazooka",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Super Bazooka — A minimalist GUI client for Claude",
    "longDescription": "Super Bazooka (90火) — A clean, fast, developer-friendly desktop interface for Claude Code CLI, with multi-provider backend support.",
    "copyright": "© 2026 cc-gui contributors",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "SimpChinese"]
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
