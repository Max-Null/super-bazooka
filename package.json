{
  "name": "super-bazooka",
  "version": "0.1.5",
  "description": "Super Bazooka (90火) — A minimalist GUI client for Claude. Tauri 2 + Vue 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --pool=forks --no-cache",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test --grep 'chat flow|visual'",
    "test:e2e:real": "bash scripts/record_claude_output.sh 'hello' && npx playwright test e2e/real-stream.spec.ts",
    "test:rust": "cd src-tauri && cargo test",
    "test:rust:real": "cd src-tauri && cargo test --test resume_test -- --ignored --nocapture",
    "test:all": "vitest run && npx playwright test && cd src-tauri && cargo test",
    "test:quick": "vitest run && cd src-tauri && cargo test",
    "build:tauri": "tauri build && npm run package:portable",
    "build:tauri:msi": "tauri build --bundles msi",
    "build:tauri:nsis": "tauri build --bundles nsis",
    "package:portable": "powershell -Command \"$v = (Get-Content package.json | ConvertFrom-Json).version; Compress-Archive -Path 'src-tauri/target/release/super-bazooka.exe', 'src-tauri/target/release/WebView2Loader.dll' -DestinationPath ('src-tauri/target/release/bundle/super-bazooka_v' + $v + '_portable.zip') -Force\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-i18n": "^10.0.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "daisyui": "^5.5.20",
    "happy-dom": "^20.10.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
